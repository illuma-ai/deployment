{
  "family": "illuma-ai-code-executor-td-prod",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "2048",
  "memory": "4096",
  "executionRoleArn": "arn:aws:iam::423159469683:role/illuma-ai-ecs-execution-role-prod",
  "taskRoleArn": "arn:aws:iam::423159469683:role/illuma-ai-ecs-task-role-prod",
  "containerDefinitions": [
    {
      "name": "illuma-ai-code-executor",
      "image": "423159469683.dkr.ecr.us-east-1.amazonaws.com/illuma-ai-code-executor-prod:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8088,
          "hostPort": 8088,
          "protocol": "tcp"
        }
      ],
      "secrets": [
        { "name": "PORT", "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/prod/code-executor-FOW6R4:PORT::" },
        { "name": "LOG_LEVEL", "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/prod/code-executor-FOW6R4:LOG_LEVEL::" },
        { "name": "CODE_API_KEY", "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/prod/code-executor-FOW6R4:CODE_API_KEY::" },
        { "name": "MAX_EXECUTION_TIME", "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/prod/code-executor-FOW6R4:MAX_EXECUTION_TIME::" },
        { "name": "MAX_MEMORY_MB", "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/prod/code-executor-FOW6R4:MAX_MEMORY_MB::" },
        { "name": "MAX_OUTPUT_SIZE", "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/prod/code-executor-FOW6R4:MAX_OUTPUT_SIZE::" },
        { "name": "USE_REDIS", "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/prod/code-executor-FOW6R4:USE_REDIS::" },
        { "name": "REDIS_URI", "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/prod/code-executor-FOW6R4:REDIS_URI::" },
        { "name": "REDIS_DB", "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/prod/code-executor-FOW6R4:REDIS_DB::" },
        { "name": "REDIS_KEY_PREFIX", "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/prod/code-executor-FOW6R4:REDIS_KEY_PREFIX::" },
        { "name": "FILE_STRATEGY", "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/prod/code-executor-FOW6R4:FILE_STRATEGY::" },
        { "name": "AWS_BUCKET_NAME", "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/prod/code-executor-FOW6R4:AWS_BUCKET_NAME::" },
        { "name": "AWS_REGION", "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/prod/code-executor-FOW6R4:AWS_REGION::" },
        { "name": "S3_URL_EXPIRY_SECONDS", "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/prod/code-executor-FOW6R4:S3_URL_EXPIRY_SECONDS::" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/illuma-ai-code-executor-prod",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -f http://localhost:8088/health || exit 1"],
        "interval": 30,
        "timeout": 10,
        "retries": 5,
        "startPeriod": 60
      }
    }
  ]
}
