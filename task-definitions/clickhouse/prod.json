{
  "family": "illuma-ai-clickhouse-td-prod",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::423159469683:role/illuma-ai-ecs-execution-role-prod",
  "taskRoleArn": "arn:aws:iam::423159469683:role/illuma-ai-ecs-task-role-prod",
  "containerDefinitions": [
    {
      "name": "illuma-ai-clickhouse",
      "image": "423159469683.dkr.ecr.us-east-1.amazonaws.com/illuma-ai-clickhouse-prod:24.3",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8123,
          "hostPort": 8123,
          "protocol": "tcp"
        },
        {
          "containerPort": 9000,
          "hostPort": 9000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "CLICKHOUSE_USER",
          "value": "default"
        },
        {
          "name": "CLICKHOUSE_PASSWORD",
          "value": "clickhouse"
        },
        {
          "name": "CLICKHOUSE_DEFAULT_ACCESS_MANAGEMENT",
          "value": "1"
        }
      ],
      "mountPoints": [
        {
          "sourceVolume": "clickhouse-data",
          "containerPath": "/var/lib/clickhouse",
          "readOnly": false
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/illuma-ai-clickhouse-prod",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "wget -q --spider http://localhost:8123/ping || exit 1"
        ],
        "interval": 30,
        "timeout": 10,
        "retries": 3,
        "startPeriod": 60
      }
    }
  ],
  "volumes": [
    {
      "name": "clickhouse-data",
      "efsVolumeConfiguration": {
        "fileSystemId": "fs-0391a3da6b2601a5a",
        "rootDirectory": "/",
        "transitEncryption": "ENABLED",
        "authorizationConfig": {
          "accessPointId": "fsap-0aecaf06757315d72",
          "iam": "DISABLED"
        }
      }
    }
  ]
}
