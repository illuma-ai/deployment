          "name": "NODE_ENV",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/chat-v2-la57J1:NODE_ENV::"
        },
        {
          "name": "NO_INDEX",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/chat-v2-la57J1:NO_INDEX::"
        },
        {
          "name": "PORT",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/chat-v2-la57J1:PORT::"
        },
        {
          "name": "RAG_API_URL",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/chat-v2-la57J1:RAG_API_URL::"
        },
        {
          "name": "REDIS_URI",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/chat-v2-la57J1:REDIS_URI::"
        },
        {
          "name": "REFRESH_TOKEN_EXPIRY",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/chat-v2-la57J1:REFRESH_TOKEN_EXPIRY::"
        },
        {
          "name": "SEARCH",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/chat-v2-la57J1:SEARCH::"
        },
        {
          "name": "SERPER_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/chat-v2-la57J1:SERPER_API_KEY::"
        },
        {
          "name": "SESSION_EXPIRY",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/chat-v2-la57J1:SESSION_EXPIRY::"
        },
        {
          "name": "TRUST_PROXY",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/chat-v2-la57J1:TRUST_PROXY::"
        },
        {
          "name": "USE_REDIS",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/chat-v2-la57J1:USE_REDIS::"
        },
        {
          "name": "VOICE_SERVICE_URL",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/chat-v2-la57J1:VOICE_SERVICE_URL::"
        },
        {
          "name": "VOICE_SESSION_SECRET",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/chat-v2-la57J1:VOICE_SESSION_SECRET::"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/illuma-ai-chat-dev",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "wget -q --spider http://localhost:3080/api/health || exit 1"
        ],
        "interval": 30,
        "timeout": 10,
        "retries": 5,
        "startPeriod": 180
      }
    }
  ]
}
