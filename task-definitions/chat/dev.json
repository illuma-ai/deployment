          "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/chat-HcimnA:HOST::"
        },
        {
          "name": "PORT",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/chat-HcimnA:PORT::"
        },
        {
