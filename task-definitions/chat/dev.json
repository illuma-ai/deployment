        },
        {
          "name": "ENDPOINTS",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/chat-v2-la57J1:ENDPOINTS::"
        },
        {
          "name": "FIRECRAWL_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/chat-v2-la57J1:FIRECRAWL_API_KEY::"
