{
  "family": "illuma-ai-chat-td-dev",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::423159469683:role/illuma-ai-ecs-execution-role-dev",
  "taskRoleArn": "arn:aws:iam::423159469683:role/illuma-ai-ecs-task-role-dev",
  "containerDefinitions": [
    {
      "name": "illuma-ai-chat",
      "image": "423159469683.dkr.ecr.us-east-1.amazonaws.com/illuma-ai-chat-dev:chatv2-latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3080,
          "hostPort": 3080,
          "protocol": "tcp"
        }
      ],
      "secrets": [
        {
          "name": "AGENT_BRIDGE_ADMIN_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/chat-v2-la57J1:AGENT_BRIDGE_ADMIN_KEY::"
        },
        {
          "name": "AGENT_BRIDGE_EVENTS_SECRET",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/chat-v2-la57J1:AGENT_BRIDGE_EVENTS_SECRET::"
        },
        {
          "name": "AGENT_BRIDGE_URL",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/chat-v2-la57J1:AGENT_BRIDGE_URL::"
        },
        {
          "name": "ALLOW_EMAIL_LOGIN",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/chat-v2-la57J1:ALLOW_EMAIL_LOGIN::"
        },
        {
          "name": "ALLOW_REGISTRATION",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/chat-v2-la57J1:ALLOW_REGISTRATION::"
        },
        {
          "name": "ALLOW_SOCIAL_LOGIN",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/chat-v2-la57J1:ALLOW_SOCIAL_LOGIN::"
        },
        {
          "name": "ALLOW_UNVERIFIED_EMAIL_LOGIN",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/chat-v2-la57J1:ALLOW_UNVERIFIED_EMAIL_LOGIN::"
        },
        {
          "name": "APP_TITLE",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/chat-v2-la57J1:APP_TITLE::"
        },
        {
          "name": "AWS_ACCESS_KEY_ID",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/chat-v2-la57J1:AWS_ACCESS_KEY_ID::"
        },
        {
          "name": "AWS_BUCKET_NAME",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/chat-v2-la57J1:AWS_BUCKET_NAME::"
        },
        {
