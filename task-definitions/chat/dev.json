          "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/chat-v2-la57J1:AWS_REGION::"
        },
        {
          "name": "AWS_SECRET_ACCESS_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/chat-v2-la57J1:AWS_SECRET_ACCESS_KEY::"
        },
        {
          "name": "BEDROCK_AWS_ACCESS_KEY_ID",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/chat-v2-la57J1:BEDROCK_AWS_ACCESS_KEY_ID::"
