{
  "family": "illuma-ai-nexillo-mcp-td-dev",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::423159469683:role/illuma-ai-ecs-execution-role-dev",
  "taskRoleArn": "arn:aws:iam::423159469683:role/illuma-ai-ecs-task-role-dev",
  "containerDefinitions": [
    {
      "name": "illuma-ai-nexillo-mcp",
      "image": "423159469683.dkr.ecr.us-east-1.amazonaws.com/illuma-ai-nexillo-mcp-dev:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3004,
          "hostPort": 3004,
          "protocol": "tcp"
        }
      ],
      "secrets": [
        { "name": "NEXILLO_API_BASE_URL", "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/nexillo-mcp-MDW8gA:NEXILLO_API_BASE_URL::" },
        { "name": "NEXILLO_API_TOKEN", "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/nexillo-mcp-MDW8gA:NEXILLO_API_TOKEN::" },
        { "name": "PORT", "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/nexillo-mcp-MDW8gA:PORT::" },
        { "name": "LOG_LEVEL", "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/nexillo-mcp-MDW8gA:LOG_LEVEL::" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/illuma-ai-nexillo-mcp-dev",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "wget -q --spider http://localhost:3004/nexillo-mcp/health || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 30
      }
    }
  ]
}
