{
  "family": "illuma-ai-mongodb-td-prod",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "256",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::423159469683:role/illuma-ai-ecs-execution-role-prod",
  "taskRoleArn": "arn:aws:iam::423159469683:role/illuma-ai-ecs-task-role-prod",
  "containerDefinitions": [
    {
      "name": "illuma-ai-mongodb",
      "image": "mongo:7.0",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 27017,
          "hostPort": 27017,
          "protocol": "tcp"
        }
      ],
      "mountPoints": [
        {
          "sourceVolume": "mongodb-data",
          "containerPath": "/data/db",
          "readOnly": false
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/illuma-ai-mongodb-prod",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "mongosh --eval 'db.runCommand({ping:1}).ok' --quiet || exit 1"
        ],
        "interval": 30,
        "timeout": 10,
        "retries": 3,
        "startPeriod": 60
      }
    }
  ],
  "volumes": [
    {
      "name": "mongodb-data",
      "efsVolumeConfiguration": {
        "fileSystemId": "fs-0436edf2469e8d003",
        "rootDirectory": "/",
        "transitEncryption": "ENABLED",
        "authorizationConfig": {
          "accessPointId": "fsap-0cc5c1c02703334e5",
          "iam": "DISABLED"
        }
      }
    }
  ]
}
