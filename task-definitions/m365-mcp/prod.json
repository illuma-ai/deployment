{
  "family": "illuma-ai-m365-mcp-td-prod",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::423159469683:role/illuma-ai-ecs-execution-role-prod",
  "taskRoleArn": "arn:aws:iam::423159469683:role/illuma-ai-ecs-task-role-prod",
  "containerDefinitions": [
    {
      "name": "illuma-ai-m365-mcp",
      "image": "423159469683.dkr.ecr.us-east-1.amazonaws.com/illuma-ai-m365-mcp-prod:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3003,
          "hostPort": 3003,
          "protocol": "tcp"
        }
      ],
      "secrets": [
        { "name": "PORT", "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/prod/m365-mcp-j4TdEu:PORT::" },
        { "name": "LOG_LEVEL", "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/prod/m365-mcp-j4TdEu:LOG_LEVEL::" },
        { "name": "MS365_MCP_OUTPUT_FORMAT", "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/prod/m365-mcp-j4TdEu:MS365_MCP_OUTPUT_FORMAT::" },
        { "name": "M365_MCP_CLIENT_SECRET", "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/prod/m365-mcp-j4TdEu:M365_MCP_CLIENT_SECRET::" },
        { "name": "M365_MCP_TENANT_ID", "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/prod/m365-mcp-j4TdEu:M365_MCP_TENANT_ID::" },
        { "name": "M365_MCP_CLIENT_ID", "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/prod/m365-mcp-j4TdEu:M365_MCP_CLIENT_ID::" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/illuma-ai-m365-mcp-prod",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -f http://localhost:3003/sharepoint-mcp/health || exit 1"],
        "interval": 30,
        "timeout": 10,
        "retries": 5,
        "startPeriod": 60
      }
    }
  ]
}
