{
  "family": "illuma-ai-observe-td-dev",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::423159469683:role/illuma-ai-ecs-execution-role-dev",
  "taskRoleArn": "arn:aws:iam::423159469683:role/illuma-ai-ecs-task-role-dev",
  "containerDefinitions": [
    {
      "name": "illuma-ai-observe",
      "image": "423159469683.dkr.ecr.us-east-1.amazonaws.com/illuma-ai-observe-dev:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8090,
          "hostPort": 8090,
          "protocol": "tcp"
        }
      ],
      "secrets": [
        {
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/observe-ERkgmT:DATABASE_URL::"
        },
        {
          "name": "CLICKHOUSE_URL",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/observe-ERkgmT:CLICKHOUSE_URL::"
        },
        {
          "name": "CLICKHOUSE_DB",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/observe-ERkgmT:CLICKHOUSE_DB::"
        },
        {
          "name": "REDIS_URI",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/observe-ERkgmT:REDIS_URI::"
        },
        {
          "name": "PORT",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/observe-ERkgmT:PORT::"
        },
        {
          "name": "NODE_ENV",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/observe-ERkgmT:NODE_ENV::"
        },
        {
          "name": "JWT_SECRET",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/observe-ERkgmT:JWT_SECRET::"
        },
        {
          "name": "JWT_REFRESH_SECRET",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/observe-ERkgmT:JWT_REFRESH_SECRET::"
        },
        {
          "name": "CORS_ORIGINS",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/observe-ERkgmT:CORS_ORIGINS::"
        },
        {
          "name": "DOMAIN_CLIENT",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/observe-ERkgmT:DOMAIN_CLIENT::"
        },
        {
          "name": "DOMAIN_SERVER",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/observe-ERkgmT:DOMAIN_SERVER::"
        },
        {
          "name": "AUTH_MODE",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/observe-ERkgmT:AUTH_MODE::"
        },
        {
          "name": "ALLOW_REGISTRATION",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/observe-ERkgmT:ALLOW_REGISTRATION::"
        },
        {
          "name": "ALLOW_SOCIAL_REGISTRATION",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/observe-ERkgmT:ALLOW_SOCIAL_REGISTRATION::"
        },
        {
          "name": "LLM_PROVIDER",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/observe-ERkgmT:LLM_PROVIDER::"
        },
        {
          "name": "AWS_REGION",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/observe-ERkgmT:AWS_REGION::"
        },
        {
          "name": "AWS_ACCESS_KEY_ID",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/observe-ERkgmT:AWS_ACCESS_KEY_ID::"
        },
        {
          "name": "AWS_SECRET_ACCESS_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/observe-ERkgmT:AWS_SECRET_ACCESS_KEY::"
        },
        {
          "name": "AWS_BEDROCK_MODEL",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/observe-ERkgmT:AWS_BEDROCK_MODEL::"
        },
        {
          "name": "ENCRYPTION_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/observe-ERkgmT:ENCRYPTION_KEY::"
        },
        {
          "name": "MODEL_MATCH_CACHE_ENABLED",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/observe-ERkgmT:MODEL_MATCH_CACHE_ENABLED::"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/illuma-ai-observe-dev",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "wget -q --spider http://localhost:8090/health || exit 1"
        ],
        "interval": 30,
        "timeout": 10,
        "retries": 5,
        "startPeriod": 120
      }
    }
  ]
}
