{
  "family": "illuma-ai-memory-td-dev",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::423159469683:role/illuma-ai-ecs-execution-role-dev",
  "taskRoleArn": "arn:aws:iam::423159469683:role/illuma-ai-ecs-task-role-dev",
  "containerDefinitions": [
    {
      "name": "illuma-ai-memory",
      "image": "423159469683.dkr.ecr.us-east-1.amazonaws.com/illuma-ai-memory-dev:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8001,
          "hostPort": 8001,
          "protocol": "tcp"
        }
      ],
      "secrets": [
        { "name": "PORT", "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/memory-ctr6ZG:PORT::" },
        { "name": "LOG_LEVEL", "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/memory-ctr6ZG:LOG_LEVEL::" },
        { "name": "ENDPOINT", "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/memory-ctr6ZG:ENDPOINT::" },
        { "name": "VECTOR_STORE", "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/memory-ctr6ZG:VECTOR_STORE::" },
        { "name": "AWS_ACCESS_KEY_ID", "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/memory-ctr6ZG:AWS_ACCESS_KEY_ID::" },
        { "name": "AWS_SECRET_ACCESS_KEY", "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/memory-ctr6ZG:AWS_SECRET_ACCESS_KEY::" },
        { "name": "AWS_REGION", "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/memory-ctr6ZG:AWS_REGION::" },
        { "name": "BEDROCK_LLM_MODEL", "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/memory-ctr6ZG:BEDROCK_LLM_MODEL::" },
        { "name": "BEDROCK_EMBEDDING_MODEL", "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/memory-ctr6ZG:BEDROCK_EMBEDDING_MODEL::" },
        { "name": "EMBEDDING_DIMENSION", "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/memory-ctr6ZG:EMBEDDING_DIMENSION::" },
        { "name": "POSTGRES_HOST", "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/memory-ctr6ZG:POSTGRES_HOST::" },
        { "name": "POSTGRES_PORT", "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/memory-ctr6ZG:POSTGRES_PORT::" },
        { "name": "POSTGRES_USER", "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/memory-ctr6ZG:POSTGRES_USER::" },
        { "name": "POSTGRES_PASSWORD", "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/memory-ctr6ZG:POSTGRES_PASSWORD::" },
        { "name": "POSTGRES_DB", "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/memory-ctr6ZG:POSTGRES_DB::" },
        { "name": "ENABLE_CONFLICT_RESOLUTION", "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/memory-ctr6ZG:ENABLE_CONFLICT_RESOLUTION::" },
        { "name": "CONFLICT_SIMILARITY_THRESHOLD", "valueFrom": "arn:aws:secretsmanager:us-east-1:423159469683:secret:illuma-ai/dev/memory-ctr6ZG:CONFLICT_SIMILARITY_THRESHOLD::" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/illuma-ai-memory-dev",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -f http://localhost:8001/health || exit 1"],
        "interval": 30,
        "timeout": 10,
        "retries": 5,
        "startPeriod": 120
      }
    }
  ]
}
